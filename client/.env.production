# Split deploy: static client (Vercel) talks to game server (Render).
# Both lobbies/auth HTTP API and gameplay WebSocket use this host.
VITE_WS_URL=wss://cursorplatformer.onrender.com
# Optional override — if unset, https:// is derived from VITE_WS_URL.
VITE_API_URL=https://cursorplatformer.onrender.com
